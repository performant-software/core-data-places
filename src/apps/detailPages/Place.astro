---
import RecordDetail from '@apps/detailPages/RecordDetail.astro';
import PageStoreProvider from '@components/PageStoreProvider';
import config from '@config';
import PlacesService from '@services/coreData/places';

const { lang, uuid } = Astro.props;

const { place } = await PlacesService.getOne(uuid);
const excludes = config.result_filtering?.places?.exclude || [];

const geometry = excludes.includes('place_geometry') ? null : place?.place_geometry;
---

<RecordDetail
  excludes={excludes}
  geometry={geometry}
  lang={lang}
  model='places'
  name={place.name}
  record={place}
/>

<PageStoreProvider
  title={place.name}
  client:load
/>