---
import RecordDetail from '@apps/detailPages/RecordDetail.astro';
import PageStoreProvider from '@components/PageStoreProvider';
import config from '@config';
import InstancesService from '@services/coreData/instances';

const { lang, uuid } = Astro.props;

const { instance } = await InstancesService.getOne(uuid);
const excludes = config.result_filtering?.instances?.exclude || [];

---

<RecordDetail
  excludes={excludes}
  lang={lang}
  model='instances'
  name={instance.name}
  record={instance}
/>

<PageStoreProvider
  title={instance.name}
  client:load
/>