---
import PostContent from '@apps/posts/PostContent';
import { getTranslations } from '@backend/i18n';
import { fetchPostResponse } from '@backend/tina';
import Container from '@components/Container.astro';
import PageStoreProvider from '@components/PageStoreProvider';
import { Icon } from '@performant-software/core-data/ssr';
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props {
  slug: string;
  publishedOnly?: boolean;
}

const { slug, publishedOnly } = Astro.props;

const [{ t }, postResponse] = await Promise.all([
  getTranslations(Astro.currentLocale),
  fetchPostResponse(slug)
]);

const post = postResponse?.data?.post;

if (publishedOnly && !post.published) {
  return new Response(null, { status: 404 });
}

const date = post?.date ? new Date(post.date).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric'
}) : null;

---

<div class='bg-primary w-full pb-12 pt-8'>
  <Container>
    <a
      class='pb-8 flex items-center gap-2'
      href={getRelativeLocaleUrl(Astro.currentLocale, 'posts')}
    >
      <Icon
        name='left_arrow'
        size={24}
      />
      <span class='uppercase font-semibold'>{t('allPosts')}</span>
    </a>
    <div class='flex flex-col gap-6 w-full items-center text-layout font-header'>
      {
        post?.category && <h4 class='italic'>{post.category}</h4>
      }
      <h1 class='text-3xl'>{post?.title}</h1>
      {
        (post?.author || post?.date) && ( 
          <div class='flex flex-row w-full justify-center gap-6 md:gap-8 italic flex-wrap'>
            {post?.author && <p>{t('by', { author: post.author })}</p>}
            {date && <p>{date}</p>}
          </div>
        )
      }
    </div>
  </Container>
</div>
<Container className='py-12 w-full'>
  <PostContent
    {...postResponse}
    client:only='react'
  />
</Container>

<PageStoreProvider
  title={post.title}
  client:load
/>