---
import clsx from 'clsx';
import Container from '@components/Container.astro';
import LinkButton from '@components/LinkButton';
import SearchBar from '@apps/pages/SearchBar';
import RichText from '@components/RichText.astro';
import { toBackgroundClass } from '@utils/pageBuilder';

const Height = {
  small: 'small',
  medium: 'medium',
  large: 'large'
};

const {
  background, 
  buttonText,
  content,
  color, 
  darken, 
  height,
  hero,
  home, 
  image,
  imageAlt,
  justify,
  search,
  subtitle,
  textAlignment,
  title,
  url
} = Astro.props;

---

<div
  class={clsx(
    'w-full relative flex flex-col justify-center overflow-hidden',
    background && toBackgroundClass(background),
    hero && 'hero pt-[72px]',
    hero && home && 'home-hero pb-[80px]',
    hero && !home && 'pb-[64px]',
    { 'items-center': textAlignment === 'center' },
    { 'min-h-[220px]': height === Height.small },
    { 'min-h-[400px]': height === Height.medium },
    { 'min-h-[600px]': height === Height.large },
    { 'text-text-inverse': color !== 'black' },
    { 'bg-primary': hero && !background }
  )}
>
  { image && (
    <img 
      src={image} 
      alt={imageAlt} 
      class={clsx(
        'w-full h-full object-cover absolute inset-0',
        { 'relative' : !(title || subtitle || url || content?.children?.length) }
      )} 
    /> 
  ) }
  { darken && (
    <div
      class='absolute top-0 left-0 w-full h-full bg-tertiary mix-blend-multiply'
    /> 
  ) }
  { !!(title || subtitle || url || content?.children?.length) && (
    <Container className={clsx(
      'flex flex-col w-full overflow-hidden',
      { 'items-center text-center': textAlignment === 'center' },
      justify
    )} >
      <div
        class={clsx(
          'relative flex flex-col z-10 text-white py-16 w-full 2xl:w-[80%] gap-y-8',
          { 'items-center text-center lg:max-w-full': textAlignment === 'center' }
        )}
      >
        { title && (
          <h1
            class={clsx(
              'banner-header leading-[1.3] m-0',
              hero && 'banner-hero',
              home && 'banner-home'
            )}
          >
            { title }
          </h1>
        )}
        { subtitle && (
          <p
            class='font-light'
          >
            { subtitle }
          </p>
        )}
        { url && (
          <div
            class='z-10'
          >
            <LinkButton
              color='secondary'
              content={buttonText}
              href={url}
            />
          </div>
        )}
        { content && content.children?.length ? (
          <div class={clsx(
            'prose max-w-none z-10 w-full',
            { 'text-center': textAlignment === 'center' },
            { 'text-text-inverse': color !== 'black' }
          )}>
            <RichText content={content} />
          </div> 
        ) : null }
        { search && ( 
          <SearchBar 
            buttonText={search.button_text}
            searchName={search.search_name}
            placeholder={search.placeholder}
            client:only="react"
          />
        )}
      </div>
    </Container>
  )}
</div>