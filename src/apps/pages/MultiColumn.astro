---
import Container from '@components/Container.astro';
import MultiColumnContent from '@components/MultiColumnContent.astro';
import clsx from 'clsx';
import { toBackgroundClass } from '@root/src/utils/pageBuilder';

const { 
  background,
  backgroundImage,
  buttonText,
  content, 
  darken,
  gap,   
  textAlignment,
  title,
  url
} = Astro.props;

---

{ backgroundImage && (
  <img 
    src={backgroundImage} 
    class='w-full h-full object-cover absolute inset-0'
  /> 
) }
{ darken && (
  <div
    class='absolute top-0 left-0 w-full h-full bg-tertiary mix-blend-multiply'
  /> 
) }
<Container>
  <MultiColumnContent
    buttonText={buttonText}
    textAlignment={textAlignment}
    title={title}
    url={url}
    content={content}
    gap={gap}
  />
</Container>