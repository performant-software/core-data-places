---
import { getTranslations } from '@backend/i18n';
import Card from '@components/Card.astro';
import RichText from '@apps/pages/sections/RichText.astro';
import Spacer from './Spacer.astro';
import clsx from 'clsx';
import { toBorderClass, toBackgroundClass } from '@root/src/utils/pageBuilder';
import _ from 'underscore';

const { item } = Astro.props;

const { t } = await getTranslations(Astro.currentLocale);

const BlockTypes = {
  basic: 'Basic',
  card: 'Card',
  counter: 'Counter',
  image: 'Image',
  imageLink: 'Image_link',
  linkRow: 'Link_row',
  quote: 'Quote',
  text: 'Richtext'
}
---
{ item.__typename.endsWith(BlockTypes.image) && ( 
  <img src={item.image} class={clsx(
    'w-full object-cover',
    { 'h-full': item.full_height },
    { 'rounded-md': item.rounded }
  )} />
)}

{ item.__typename.endsWith(BlockTypes.text) && ( 
  <div class={clsx(
    'prose max-w-none py-8 lg:py-4 text-inherit',
    item.padding && 'px-4',
    item.size
  )}>
    <RichText content={item.text} />
  </div>
)}

{ !item.__typename || item.__typename.endsWith(BlockTypes.basic) && ( 
  <div
    class='flex flex-col w-full'
  >
    <h4
      class='text-3xl font-bold'
    >
      { item?.title }
    </h4>
    <p
      class='font-light'
    >
      { item?.description }
    </p>
  </div>
)}

{ item.__typename.endsWith(BlockTypes.card) && ( 
  <Card
    alt={item.alt}
    author={item.author}
    blur={item.blurb}
    category={item.category}
    date={item.date}
    imageUrl={item.image}
    slug={item.slug}
    t={t}
    title={item.title}
  />
)}

{ item.__typename.endsWith(BlockTypes.quote) && ( 
  <div class={clsx(
    'flex flex-col relative p-8 gap-8',
    item.bg_color && 'h-full',
    item.text_color,
    toBorderClass(item.border_color),
    toBackgroundClass(item.bg_color),
    { 'items-center text-center': item.text_alignment === 'center' }
  )}>
    <img src={item.icon} class={clsx(
      'w-12 h-12',
      item.icon_background && 'absolute top-4 left-4 opacity-20'
     )} />
    <p class='font-serif text-xl'>
      { item.quote }
    </p>
    { item.border_color && <Spacer size='none' color={item.border_color} /> }
    <p class='font-semibold -indent-2 pl-2 italic text-sm lg:max-w-[80%]'>
      { item.attribution }
    </p>
  </div>
)}

{ item.__typename.endsWith(BlockTypes.imageLink) && ( 
  <a href={item.link} class='relative'>
    <img src={item.image} class='w-full h-full object-contain'/>
    { item.overlay && ( 
      <div class='absolute h-full w-full inset-0 bg-gradient-to-b to-black/60 p-6 flex flex-col justify-end'>
        <h3 class='!text-text-inverse font-serif'>{ item.overlay }</h3>
      </div> 
    )}
  </a>
)}

{ item.__typename.endsWith(BlockTypes.counter) && ( 
  <div class='flex flex-col py-4 px-2 xl:px-4 gap-3 font-serif font-semibold bg-layout-alt items-center w-full h-full'>
    <div class='flex flex-col'>
      <p class='text-secondary text-5xl'>{ item.count }</p>
      <p class='italic'>{ item.type || 'records' }</p>
    </div>
    <div class='text-lg'>{ item.description }</div>
  </div>
)}

{ item.__typename.endsWith(BlockTypes.linkRow) && ( 
  <div class='flex flex-row flex-wrap font-semibold font-sans gap-5 py-1.5 justify-center'>
    {
      _.map(item.links, (link) => (
        <a href={link.url} class='no-underline hover:underline underline-offset-4 decoration-2'>
          { link.label }
        </a>
      ))
    }
  </div>
)}