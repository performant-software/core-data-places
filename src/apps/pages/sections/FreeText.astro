---
import { TinaMarkdown } from 'tinacms/dist/rich-text';
import Spacer from './mdx/Spacer';

const { content } = Astro.props;
const components = {
  spacer: Spacer
}
---

<article
  class='prose prose-lg py-8 max-w-none font-light'
>
  <TinaMarkdown
    content={content}
    components={components}
  />
</article>