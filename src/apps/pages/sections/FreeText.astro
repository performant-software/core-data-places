---
import { TinaMarkdown } from 'tinacms/dist/rich-text';
import { richTextComponents } from '@root/src/utils/pageBuilder';

const { content } = Astro.props;
---

<article
  class='prose prose-lg py-8 max-w-none font-light'
>
  <TinaMarkdown
    content={content}
    components={richTextComponents}
  />
</article>

<script>
  window.document.addEventListener('DOMContentLoaded', () => {
    const searchBars = document.querySelectorAll('#search-bar');
    for (const search of searchBars) {
      if (search instanceof HTMLElement && search.dataset.url) {
        search.addEventListener('submit', (event) => {
          event.preventDefault();
          const input = search.querySelector('input');
          window.location.href = `${search.dataset.url}${input.value}`
        })
      }
    }
  })
</script>