---
import { getRelatedGeometry, groupRelationships } from '@utils/detailPages';
import { getTranslations } from '@backend/i18n';
import ServiceFactory from '@services/coreData/factory';
import PlaceMap from '@apps/pages/RecordDetail/PlaceMap';
import { Icon } from '@performant-software/core-data/ssr';
import { hasDetailPage } from '@utils/detailPagePaths';

interface Props {
  excludes: string[];
  model: string;
  uuid: string;
}

const { excludes, model, uuid } = Astro.props;

const lang = Astro.currentLocale;
const service = ServiceFactory.getService(model);
const { places } = await service.getRelatedPlaces(uuid);
const relationships = groupRelationships(places, excludes);
const { t } = await getTranslations(lang);

const showLinks = hasDetailPage('places');
const resolveDetailUrl = (record: any) => `/${lang}/places/${record.uuid}`;
---
{Object.keys(relationships).map((uuid) => (
  <div class='py-8 w-full'>
    <h4 class='capitalize font-header mb-4'>{t(uuid)}</h4>
    <div class='grid grid-cols-[1fr_2fr] h-[300px] bg-white w-full gap-6'>
      <ul class='items-start justify-start font-body divide-y divide-neutral-200'>
        {relationships[uuid].map((place) =>
          showLinks && resolveDetailUrl ? (
            <li>
              <a
                class='flex py-4 pl-4 text-wrap items-center font-semibold'
                href={resolveDetailUrl(place)}
              >
                <Icon name='location' size={16} />
                { place.name }
              </a>
            </li>
          ) : (
            <li class='flex gap-2 my-2 text-wrap items-center font-semibold pb-2'>
              <Icon name='location' size={16} />
              { place.name }
            </li>
          )
        )}
      </ul>
      <PlaceMap
        client:only='react'
        classNames={{
          root: 'h-full!'
        }}
        geometry={getRelatedGeometry(relationships[uuid])}
        lang={lang}
      />
    </div>
  </div>
))}
