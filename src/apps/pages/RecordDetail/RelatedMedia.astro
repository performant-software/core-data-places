---
import ServiceFactory from '@services/coreData/factory';
import MediaContents from '@apps/pages/RecordDetail/MediaContents';

interface Props {
  model: string;
  uuid: string;
}

const base = Astro.url.origin;

const { model, uuid } = Astro.props;

const service = ServiceFactory.getService(model);
const manifests = await service.getRelatedManifests(uuid);
---
{manifests && manifests?.items?.length > 0 && (
  <MediaContents
    client:only='react'
    base={base}
    data={manifests}
    model={model}
    uuid={uuid}
  />
)}
