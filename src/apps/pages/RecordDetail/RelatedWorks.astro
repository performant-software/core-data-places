---
import ServiceFactory from '@services/coreData/factory';
import { getRelationshipFields, groupRelationships } from '@utils/detailPages';
import config from '@config';
import { getTranslations } from '@backend/i18n';
import RelatedSource from '@apps/pages/RecordDetail/RelatedSource.astro';

interface Props {
  excludes: string[];
  model: string;
  uuid: string;
}

const { excludes, model, uuid } = Astro.props;

const lang = Astro.currentLocale;
const service = ServiceFactory.getService(model);
const { works } = await service.getRelatedWorks(uuid);
const relationships = groupRelationships(works, excludes);
const { t } = await getTranslations(lang);

const fields = getRelationshipFields(config.detail_pages.relationship_fields?.works || [], t)

const resolveDetailUrl = (work: any) => `/${lang}/works/${work.uuid}`;
const showLinks = config.detail_pages?.models?.includes('works');
---
{Object.keys(relationships).map((uuid) => (
  <div class='py-6 w-full'>
    <h4 class='capitalize italic mb-2'>{t(uuid)}</h4>
    <div class='flex flex-col gap-4'>
      {relationships[uuid].map((work) => (
        <>
          {showLinks && (
            <a href={resolveDetailUrl(work)}>
              <RelatedSource
                fields={fields}
                record={work}
              />
            </a>
          )}
          {!showLinks && (
            <RelatedSource
              fields={fields}
              record={work}
            />
          )}
        </>
      ))}
    </div>
  </div>
))}