---
import PageBody from '@components/PageBody.astro';
import PageStoreProvider from '@components/PageStoreProvider';
import { getHomepage } from '@utils/nav';

const locale = Astro.currentLocale;
const page = await getHomepage(locale);

---

<PageBody
  sections={page?.sections}
  transparent={page?.transparent}
  home={page?.home_page}
/>

<PageStoreProvider
  title={page.title}
  client:load
/>