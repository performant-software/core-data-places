---
const {
  className,
  label,
  name,
  placeholder,
  type
} = Astro.props;
---

<div
  class={className}
>
  <div>
    <label
      for={name}
      class='block text-sm/6 font-medium text-gray-900'
    >
      { label }
    </label>
    <div
      class='mt-2'
    >
      <div
        class='flex items-center rounded-md bg-white border border-solid border-layout'
      >
        { type === 'text' && (
          <input
            class='block w-full rounded-md bg-white px-3.5 py-2'
            name={name}
            placeholder={placeholder}
            type='text'
          />
        )}
        { type === 'textarea' && (
          <textarea
            class='block w-full rounded-md bg-white px-3 py-1.5 rounded'
            name={name}
            rows='3'
          />
        )}
      </div>
    </div>
  </div>
</div>