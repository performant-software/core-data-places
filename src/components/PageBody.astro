---
import Banner from '@apps/pages/sections/Banner.astro';
import Carousel from '@apps/pages/sections/Carousel';
import FeatureQuote from '@apps/pages/sections/FeatureQuote.astro';
import FreeText from '@apps/pages/sections/FreeText.astro';
import Images from '@apps/pages/sections/Images.astro';
import MultiColumn from '@apps/pages/sections/MultiColumn.astro';
import Spacer from '@apps/pages/sections/Spacer.astro';
import Tabs from '@apps/pages/sections/Tabs.astro';
import TextImage from '@apps/pages/sections/TextImage';
import Container from '@components/Container.astro';
import clsx from 'clsx';
import _ from 'underscore';
import LinksBanner from '@apps/pages/sections/LinksBanner.astro';
import { toBackgroundClass } from '@utils/pageBuilder';

const { sections, transparent, home } = Astro.props;

const SectionTypes = {
  banner: 'Banner',
  carousel: 'Carousel',
  freeText: 'Free_text',
  images: 'Images',
  linkBanner: 'Link_banner',
  multiColumn: 'Multi_column',
  featureQuote: 'Feature_quote',
  spacer: 'Spacer',
  tabs: 'Tabs',
  textImage: 'Text_image',
};
---
{ _.map(sections, (section, idx) => (
  <section
    class={clsx(
      'page-builder',
      'relative',
      toBackgroundClass(section.background),
      section.text,
      section.top_margin,
      section.bottom_margin,
      { '-mt-[72px]': transparent && idx === 0 }
    )}
  >
    { section?.__typename?.endsWith(SectionTypes.carousel) && (
      <Container>
        <Carousel
          items={section.items}
          client:only='react'
        />
      </Container>
    )}
    { section?.__typename?.endsWith(SectionTypes.freeText) && (
      <Container>
        <FreeText
          content={section.body}
        />
      </Container>
    )}
    { section?.__typename?.endsWith(SectionTypes.images) && (
      <Container>
        <Images
          items={section.items}
          title={section.title}
        />
      </Container>
    )}
    { section?.__typename?.endsWith(SectionTypes.spacer) && (
      <Container>
        <Spacer
          color={section.color}
          size={section.size}
          thick
        />
      </Container>
    )}
    { section?.__typename?.endsWith(SectionTypes.textImage) && (
      <Container>
        <TextImage
          backgroundPosition={section.background_position}
          buttonText={section.button_text}
          citation={section.citation}
          citationLink={section.citation_link}
          description={section.description}
          image={section.image}
          imageAlt={section.image_alt}
          textPosition={section.text_position}
          title={section.title}
          url={section.url}
          client:load
        />
      </Container>
    )}
    { section?.__typename?.endsWith(SectionTypes.multiColumn) && (
      <Container>
        <MultiColumn
          buttonText={section.button_text}
          textAlignment={section.text_alignment}
          title={section.title}
          url={section.url}
          content={section.columns}
          gap={section.gap}
        />
      </Container>
    )}
    { section?.__typename?.endsWith(SectionTypes.banner) && (
      <Banner
        background={section.background}
        buttonText={section.button_text}
        clip={section.clip}
        color={section.color}
        content={section.content}
        darken={section.darken}
        fullWidth={section.full_width}
        height={section.height}
        hero={section.hero}
        home={home}
        image={section.background_image}
        imageAlt={section.background_image_alt}
        search={section.search}
        subtitle={section.subtitle}
        textAlignment={section.text_alignment}
        title={section.title}
        url={section.url}
      />
    )}
    { section?.__typename?.endsWith(SectionTypes.tabs) && ( 
        <Tabs
          tabs={section.tabs}
          raise={section.top_margin && section.top_margin.startsWith('-')}
          activeBg={section.active_bg}
          inactiveBg={section.inactive_bg}
          textStyle={section.text_style}
          invertText={section.invert_text}
        />
    )}
    { section?.__typename?.endsWith(SectionTypes.featureQuote) && ( 
      <FeatureQuote
        {...section}
      />
    )}
    { section?.__typename?.endsWith(SectionTypes.linkBanner) && ( 
      <LinksBanner
        {...section}
        linkBackground={section.link_background}
      />
    )}
  </section>
))}