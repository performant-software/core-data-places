---
import Person from '@apps/detailPages/Person.astro';
import Layout from '@layouts/Layout.astro';
import { ModelNames } from '@services/coreData/factory';
import { getDetailPagePaths } from '@utils/detailPages';

const { lang, uuid } = Astro.params;

export const getStaticPaths = async () => await getDetailPagePaths(ModelNames.people);

---

<Layout
  footer
>
  <Person
    lang={lang}
    uuid={uuid}
    server:defer
  />
</Layout>