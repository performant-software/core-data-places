---
import Paths from '@apps/paths/Paths';
import Container from '@components/Container.astro';
import config from '@config';
import Layout from '@layouts/Layout.astro';
import { hasPathsContent } from '@utils/config';
import _ from 'underscore';

export const getStaticPaths = () => {
  if (!hasPathsContent(config)) {
    return [];
  }

  return _.map(config.i18n.locales, (lang: string) => ({ params: { lang }}));
};

---

<Layout
  footer
  titleKey='paths'
>
  <Container
    className='pb-16 w-full'
  >
    <Paths
      lang={Astro.currentLocale}
      sort={config.content?.paths_config?.sort_by}
      client:only='react'
    />
  </Container>
</Layout>