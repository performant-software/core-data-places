---
import Event from '@apps/detailPages/Event.astro';
import Layout from '@layouts/Layout.astro';
import { ModelNames } from '@services/coreData/factory';
import { getDetailPagePaths } from '@utils/detailPages';

const { lang, uuid } = Astro.params;

export const getStaticPaths = async () => await getDetailPagePaths(ModelNames.events);

---

<Layout
  footer
>
  <Event
    lang={lang}
    uuid={uuid}
    server:defer
  />
</Layout>
